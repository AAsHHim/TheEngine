PORT=3000
CRAWL_INTERVAL_MS=5000

# false = manual indexing (UI or POST /crawl/urls + /crawl/run-batch). true = background scheduler + optional seeds on boot.
AUTO_CRAWL=false

# playwright = headless Chromium (JavaScript sites). http = axios only, no browser (lighter; many SPAs index poorly).
CRAWL_FETCH_MODE=playwright
